{
  "name": "@local/ds-coding-agent",
  "version": "1.0.0",
  "exports": "./index.ts",
  "tasks": {
    "start": "deno run --allow-all index.ts",
    "test": "deno test --allow-all",
    "typecheck": "deno check index.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno task typecheck && deno task test",
    "build:bin": "deno compile --allow-all --output dist/ds-coding-agent index.ts"
  },
  "imports": {
    "ai": "npm:ai@^6.0.184",
    "@ai-sdk/deepseek": "npm:@ai-sdk/deepseek@^2.0.35",
    "dotenv": "npm:dotenv@^17.4.2",
    "execa": "npm:execa@^9.6.1",
    "zod": "npm:zod@^4.4.3",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/testing/bdd": "jsr:@std/testing@^1.0.18/bdd",
    "@std/expect": "jsr:@std/expect@^1.0.19",
    "@deno-cli-tools/prompts": "jsr:@deno-cli-tools/prompts@^1.0.2"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true
  },
  "lint": {
    "rules": {
      "exclude": ["require-await"]
    }
  }
}
